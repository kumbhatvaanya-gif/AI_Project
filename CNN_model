"relu\"),\n    layers.Dropout(0.3),\n    layers.Dense(1, activation=\"sigmoid\"),\n])\n\nmodel.compile(optimizer=\"adam\", loss=\"binary_crossentropy\", metrics=[\"accuracy\"])\nmodel.summary()\n\n# ==========================================\n# 7. Train\n# ==========================================\nhistory = model.fit(\n    X_train, y_train,\n    validation_split=0.2,\n    epochs=10,\n    batch_size=32,\n)\n\n# ==========================================\n# 8. Evaluate вҖ” raw model accuracy\n# ==========================================\ntest_loss, test_acc = model.evaluate(X_test, y_test)\nprint(f\"\\nRaw Model Test Accuracy: {test_acc:.4f}\")\n\nraw_pred_probs = model.predict(X_test)\n\n# ==========================================\n# 9. If/Else logic: convert predictions into Leukemia / No Leukemia labels\n#    (mirrors the logic from the 4-class -> binary script)\n# ==========================================\ny_true_labels = []\ny_pred_labels = []\n\nfor true_val, pred_prob in zip(y_test, raw_pred_probs):\n    pred_val = 1 if pred_prob >= 0.5 else 0\n\n    # --- True label ---\n    if true_val == 1:\n        y_true_labels.append(\"Leukemia\")\n    else:\n        y_true_labels.append(\"No Leukemia\")\n\n    # --- Predicted label ---\n    if pred_val == 1:\n        y_pred_labels.append(\"Leukemia\")\n    else:\n        y_pred_labels.append(\"No Leukemia\")\n\nbinary_accuracy = accuracy_score(y_true_labels, y_pred_labels)\n\nprint(\"\\n================== LEUKEMIA DETECTION REPORT ==================\")\nprint(f\"Binary Accuracy (Leukemia vs No Leukemia): {binary_accuracy*100:.2f}%\\n\")\nprint(classification_report(y_true_labels, y_pred_labels, target_names=[\"Leukemia\", \"No Leukemia\"]))\nprint(\"=================================================================\\n\")\n\nprint(\"Confusion Matrix:\")\nprint(confusion_matrix(y_true_labels, y_pred_labels, labels=[\"Leukemia\", \"No Leukemia\"]))","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-10T